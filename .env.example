APP_NAME=LangChain SRE POC
APP_ENV=development

DATABASE_URL=sqlite:///./sre.db
MONITORED_BASE_URL=http://localhost:8000
MONITOR_INTERVAL_SECONDS=60

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=sre-poc@example.com
ALERT_RECIPIENT=sre-team@example.com
SMTP_USE_TLS=true
ENABLE_EMAIL_ALERTS=false
